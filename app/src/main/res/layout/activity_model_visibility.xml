<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="@color/background">

    <android.support.v7.widget.Toolbar
        android:id="@+id/toolbar"
        style="@style/AppToolbar"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:title="@string/selected_models">

        <android.support.v7.widget.AppCompatImageButton
            android:id="@+id/refresh_models_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="right|center_vertical"
            android:layout_marginRight="8dp"
            android:background="@drawable/bg_icon_button"
            android:contentDescription="@string/refresh_models"
            android:padding="8dp"
            android:src="@drawable/ic_refresh" />
    </android.support.v7.widget.Toolbar>

    <ListView
        android:id="@+id/models_list"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_below="@id/toolbar"
        android:cacheColorHint="@color/background"
        android:clipToPadding="false"
        android:divider="@null"
        android:dividerHeight="0dp"
        android:paddingLeft="12dp"
        android:paddingTop="12dp"
        android:paddingRight="12dp"
        android:paddingBottom="12dp" />
</RelativeLayout>
